# PostgreSQL connection string
DATABASE_URL=postgres://dev:dev@localhost:5432/movieclub?sslmode=disable

# Server port (Cloud Run sets this automatically in production)
PORT=8080

# Session cookie secret (CHANGE IN PRODUCTION)
SESSION_SECRET=change-me-in-production

# OMDb API key — get one free at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# "development" or "production"
NODE_ENV=development

# Log level: debug, info, warn, error
LOG_LEVEL=info
