# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# ── Local development ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://dev:dev@localhost:5433/movieclub?sslmode=disable
DEV_DB_URL=postgres://dev:dev@localhost:5433/movieclub?sslmode=disable
SESSION_SECRET=change-me-in-development
PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# ── OMDb API (movie search) ───────────────────────────────────────────────────
# Free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# ── GCP project ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
REGION=<GCP_REGION>
SERVICE=movieclub
REGISTRY=<GCP_REGION>-docker.pkg.dev/<GCP_PROJECT_ID>/movieclub/server
CLOUD_SQL_CONNECTION_NAME=<GCP_PROJECT_ID>:<GCP_REGION>:movieclub-db

# ── Cloud SQL — Postico / admin access ────────────────────────────────────────
# Requires Cloud SQL Auth Proxy running: make db-proxy
# Then connect Postico to:  host=127.0.0.1  port=5432  db=movieclub
#
# Admin (full read-write)
CLOUDSQL_ADMIN_USER=postgres
CLOUDSQL_ADMIN_PASS=
#
# Read-only (SELECT only on all tables)
CLOUDSQL_RO_USER=movieclub_ro
CLOUDSQL_RO_PASS=
